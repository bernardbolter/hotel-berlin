DATABASE_URL=postgresql://user@localhost:5432/hotelberlin
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Mapbox — vector maps (homepage teaser, hero map tile, /neighbourhood)
# Create a token at https://account.mapbox.com/ (public token is fine for client-side use)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Optional — defaults to mapbox/light-v11. Use your own style ID when ready, e.g. mapbox/your-username/style-id
# NEXT_PUBLIC_MAPBOX_STYLE_ID=mapbox/light-v11

# Homepage V2 client preview — omit or leave unset to hide Meetings / Culture / Map / FAQ / Footer.
# Set to "true" to re-enable the full homepage without deleting those sections.
# NEXT_PUBLIC_SHOW_FULL_HOMEPAGE=true

# Production / Netcup: set true on first boot (or after schema changes) so Payload can sync tables.
# Remove or set false once the schema is stable.
# PAYLOAD_DATABASE_PUSH=true

# ISR revalidation for places (optional in dev)
# REVALIDATE_SECRET=
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# On Netcup use the public URL, e.g. https://preview.your-domain.com
